<%- include('../partials/header') %>

<div class="space-y-8 animate-fade-in">
  <!-- Page Header -->
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-100">Payments Ledger</h1>
      <p class="text-sm text-slate-400 mt-1">Review historical credit transactions and income statements.</p>
    </div>
    <a href="/payments/new" class="bg-gradient-to-r from-yellow-600 to-[#C29B5C] hover:from-amber-600 hover:to-yellow-500 text-slate-950 font-bold py-2.5 px-6 rounded-xl transition duration-150 shadow-md text-xs uppercase tracking-wider flex items-center space-x-1.5">
      <i class="fa-solid fa-file-invoice-dollar"></i>
      <span>Record Payment</span>
    </a>
  </div>

  <!-- Payments Table -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl shadow-md overflow-hidden">
    <% if (payments.length === 0) { %>
      <div class="p-8 text-center text-slate-500 text-sm">
        <i class="fa-solid fa-receipt text-2xl mb-2 block text-slate-600"></i>
        No payment records registered in the system.
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-slate-300">
          <thead class="text-xs uppercase tracking-wider text-slate-500 bg-slate-900 border-b border-slate-800/80">
            <tr>
              <th class="px-6 py-4 font-semibold">Payment Date</th>
              <th class="px-6 py-4 font-semibold">Client Name</th>
              <th class="px-6 py-4 font-semibold text-right">Amount Received</th>
              <th class="px-6 py-4 font-semibold">Payment Type</th>
              <th class="px-6 py-4 font-semibold">Payment Mode</th>
              <th class="px-6 py-4 font-semibold">Recorded By</th>
              <th class="px-6 py-4 font-semibold">Remarks/Notes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/60 bg-slate-900/50">
            <% payments.forEach(payment => { %>
              <tr class="hover:bg-slate-800/30 transition-colors duration-150">
                <!-- Payment Date -->
                <td class="px-6 py-4 text-xs font-medium select-all">
                  <%= new Date(payment.payment_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </td>

                <!-- Client Name -->
                <td class="px-6 py-4 font-semibold text-slate-100">
                  <a href="/clients/<%= payment.client_id %>" class="hover:text-[#C29B5C] transition-colors"><%= payment.client_name %></a>
                </td>

                <!-- Amount -->
                <td class="px-6 py-4 text-right text-emerald-400 font-bold select-all">
                  ₹<%= parseFloat(payment.amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
                </td>

                <!-- Payment Type -->
                <td class="px-6 py-4 text-xs capitalize">
                  <span class="px-2 py-0.5 rounded bg-slate-800 text-slate-300 font-medium">
                    <%= payment.payment_type %>
                  </span>
                </td>

                <!-- Mode -->
                <td class="px-6 py-4 text-xs uppercase font-semibold text-slate-400">
                  <%= payment.payment_mode.replace('_', ' ') %>
                </td>

                <!-- Recorded By -->
                <td class="px-6 py-4 text-xs text-slate-400">
                  <%= payment.recorder_name %>
                </td>

                <!-- Notes -->
                <td class="px-6 py-4 text-xs text-slate-500 max-w-xs truncate" title="<%= payment.notes %>">
                  <%= payment.notes || '-' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
