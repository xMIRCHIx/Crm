<%- include('../partials/header') %>

<div class="space-y-8 animate-fade-in">
  <!-- Header Bar -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between space-y-4 md:space-y-0">
    <div class="flex items-center space-x-3">
      <a href="/clients" class="text-slate-400 hover:text-slate-200 bg-slate-900 border border-slate-800 p-2.5 rounded-xl transition duration-150 shadow-sm" title="Back to Registry">
        <i class="fa-solid fa-arrow-left"></i>
      </a>
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-slate-100"><%= client.name %></h1>
        <p class="text-sm text-slate-400 mt-1 capitalize"><%= client.service_type.replace('_', ' ') %> &bull; Client profile</p>
      </div>
    </div>

    <div class="flex space-x-3 items-center">
      <% if (user.role === 'admin' || user.role === 'manager') { %>
        <a href="/clients/<%= client.id %>/edit" class="bg-slate-900 border border-slate-800 hover:bg-slate-800 text-slate-300 hover:text-slate-100 font-bold py-2.5 px-5 rounded-xl transition duration-150 text-xs uppercase tracking-wider flex items-center space-x-1.5 shadow-sm">
          <i class="fa-solid fa-pen-to-square"></i>
          <span>Edit Details</span>
        </a>
      <% } %>
      <% if (user.role === 'admin') { %>
        <form action="/clients/<%= client.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete <%= client.name %>? This will permanently delete all related tasks and payments!')">
          <button type="submit" class="bg-red-950/40 hover:bg-red-900/60 text-red-400 hover:text-red-200 border border-red-900/30 hover:border-red-800/50 font-bold py-2.5 px-5 rounded-xl transition duration-150 text-xs uppercase tracking-wider flex items-center space-x-1.5 shadow-sm">
            <i class="fa-solid fa-trash"></i>
            <span>Delete Client</span>
          </button>
        </form>
      <% } %>
    </div>
  </div>

  <!-- Client Financial & Basic Cards Grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Contact Card -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-sm space-y-4">
      <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500 border-b border-slate-800 pb-2">Client Contacts</h3>
      <div class="space-y-3 text-sm">
        <div class="flex items-start space-x-3">
          <i class="fa-solid fa-envelope text-slate-500 mt-0.5 w-4 text-center"></i>
          <div>
            <span class="text-xs text-slate-500 block">Email Address</span>
            <a href="mailto:<%= client.email %>" class="text-slate-300 hover:text-[#C29B5C] break-all select-all"><%= client.email || 'N/A' %></a>
          </div>
        </div>
        <div class="flex items-start space-x-3">
          <i class="fa-solid fa-phone text-slate-500 mt-0.5 w-4 text-center"></i>
          <div>
            <span class="text-xs text-slate-500 block">Phone Number</span>
            <span class="text-slate-300 select-all"><%= client.phone || 'N/A' %></span>
          </div>
        </div>
        <div class="flex items-start space-x-3">
          <i class="fa-solid fa-location-dot text-slate-500 mt-0.5 w-4 text-center"></i>
          <div>
            <span class="text-xs text-slate-500 block">Office Address</span>
            <span class="text-slate-300"><%= client.address || 'N/A' %></span>
          </div>
        </div>
        
        <!-- Client Portal Login Access -->
        <% if (user.role === 'admin' || user.role === 'manager') { %>
          <div class="border-t border-slate-800 pt-3.5 mt-2 space-y-2">
            <span class="text-[10px] uppercase font-bold tracking-wider text-slate-500 block">Client Portal Access</span>
            <% if (portalUser) { %>
              <div class="space-y-2">
                <div class="flex items-center justify-between text-xs bg-slate-950 p-2.5 rounded-xl border border-slate-800/60">
                  <span class="text-slate-400 select-all"><%= portalUser.email %></span>
                  <span class="px-1.5 py-0.5 rounded text-[8px] font-bold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 uppercase tracking-wide">Portal Active</span>
                </div>
                <form action="/clients/<%= client.id %>/portal-login/reset-password" method="POST" class="space-y-2">
                  <div>
                    <label for="custom_password" class="block text-[9px] font-semibold uppercase tracking-wider text-slate-500 mb-1">Set Custom Password (Optional)</label>
                    <input type="text" name="custom_password" id="custom_password" placeholder="Leave blank to auto-generate"
                           class="w-full bg-slate-950 border border-slate-800 rounded-xl py-2 px-3 text-slate-200 text-xs focus:outline-none focus:border-[#C29B5C]">
                  </div>
                  <button type="submit" class="w-full bg-slate-950 hover:bg-slate-850 text-slate-300 font-bold py-1.5 px-3 rounded-xl text-[10px] transition duration-150 border border-slate-800 flex items-center justify-center space-x-1.5 shadow-sm">
                    <i class="fa-solid fa-key text-[9px]"></i>
                    <span>Reset / Change Password</span>
                  </button>
                </form>
              </div>
            <% } else { %>
              <div class="flex items-center justify-between">
                <span class="text-xs text-slate-550">No account created</span>
                <form action="/clients/<%= client.id %>/portal-login" method="POST">
                  <button type="submit" class="bg-[#C29B5C]/15 border border-[#C29B5C]/25 text-[#C29B5C] hover:bg-[#C29B5C] hover:text-slate-950 font-bold py-1.5 px-3 rounded-xl text-xs transition duration-150 flex items-center space-x-1.5">
                    <i class="fa-solid fa-user-plus text-[10px]"></i>
                    <span>Create Login</span>
                  </button>
                </form>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Project Metrics Card -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-sm space-y-4">
      <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500 border-b border-slate-800 pb-2">Project Metrics</h3>
      <div class="space-y-3 text-sm">
        <div>
          <span class="text-xs text-slate-500 block">Workflow Status</span>
          <div class="mt-1">
            <% if (client.status === 'lead') { %>
              <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-sky-500/10 text-sky-400 border border-sky-500/20 uppercase tracking-wide">Lead</span>
            <% } else if (client.status === 'ongoing') { %>
              <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-amber-500/10 text-amber-400 border border-amber-500/20 uppercase tracking-wide">Ongoing</span>
            <% } else if (client.status === 'completed') { %>
              <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 uppercase tracking-wide">Completed</span>
            <% } else if (client.status === 'on_hold') { %>
              <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-slate-500/20 text-slate-400 border border-slate-500/20 uppercase tracking-wide">On Hold</span>
            <% } %>
          </div>
        </div>
        <div>
          <span class="text-xs text-slate-500 block">Created On</span>
          <span class="text-slate-300"><%= new Date(client.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
        </div>
        <div>
          <span class="text-xs text-slate-500 block">Registered By</span>
          <span class="text-slate-300 font-semibold"><%= client.creator_name || 'System Admin' %></span>
        </div>
      </div>
    </div>

    <!-- Financial Card -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-sm space-y-4">
      <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500 border-b border-slate-800 pb-2">Billing & Accounts</h3>
      <div class="space-y-4 text-sm">
        <div class="flex justify-between items-center">
          <span class="text-xs text-slate-400">Total Project Value:</span>
          <span class="font-bold text-slate-200 select-all">₹<%= parseFloat(client.total_value).toLocaleString('en-IN') %></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-xs text-slate-400">Amount Received:</span>
          <span class="font-bold text-emerald-400 select-all">₹<%= parseFloat(client.paid_amount).toLocaleString('en-IN') %></span>
        </div>
        <div class="flex justify-between items-center border-t border-slate-800 pt-3">
          <span class="text-xs font-semibold text-slate-300">Outstanding Balance:</span>
          <span class="font-black text-[#C29B5C] text-lg select-all">₹<%= parseFloat(client.pending_amount).toLocaleString('en-IN') %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Client Project Notes -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-sm">
    <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500 border-b border-slate-800 pb-2">Project Brief / Notes</h3>
    <div class="mt-4 text-slate-300 text-sm whitespace-pre-line leading-relaxed">
      <%= client.notes || 'No project notes or remarks configured for this client.' %>
    </div>
  </div>

  <!-- Project Milestones Timeline & Manager -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-md space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-slate-800 pb-4 space-y-3 sm:space-y-0">
      <div>
        <h3 class="text-lg font-bold text-slate-100 tracking-tight">Project Milestones</h3>
        <p class="text-xs text-slate-400 mt-1">Real-time completion progress: <span class="text-[#C29B5C] font-semibold"><%= milestoneProgress %>%</span></p>
      </div>
      <div class="w-full sm:w-48 bg-slate-950 rounded-full h-2.5 overflow-hidden border border-slate-850">
        <div class="bg-gradient-to-r from-yellow-600 to-[#C29B5C] h-full rounded-full" style="width: <%= milestoneProgress %>%"></div>
      </div>
    </div>

    <!-- Milestones List -->
    <% if (milestones.length === 0) { %>
      <div class="text-center py-8 text-slate-500 text-sm">
        No milestones have been defined for this client.
      </div>
    <% } else { %>
      <div class="relative pl-6 border-l border-slate-800 space-y-6">
        <% milestones.forEach(milestone => { %>
          <div class="relative group">
            <!-- Bullet -->
            <span class="absolute -left-[31px] top-0.5 w-4.5 h-4.5 rounded-full flex items-center justify-center border-2 
              <%= milestone.status === 'completed' ? 'bg-emerald-500 border-emerald-500 text-white' : 
                  milestone.status === 'in_progress' ? 'bg-amber-500 border-amber-500 text-white' : 'bg-slate-950 border-slate-800 text-slate-650' %>">
              <% if (milestone.status === 'completed') { %>
                <i class="fa-solid fa-check text-[9px]"></i>
              <% } else if (milestone.status === 'in_progress') { %>
                <i class="fa-solid fa-spinner text-[9px] animate-spin"></i>
              <% } else { %>
                <i class="fa-solid fa-circle text-[6px]"></i>
              <% } %>
            </span>

            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center space-y-2 sm:space-y-0">
              <div>
                <h4 class="font-bold text-slate-200 text-sm"><%= milestone.title %></h4>
                <p class="text-xs text-slate-450 mt-0.5"><%= milestone.description || 'No description' %></p>
                <% if (milestone.due_date) { %>
                  <span class="text-[10px] text-slate-500 block mt-1.5"><i class="fa-regular fa-calendar mr-1"></i>Target: <%= new Date(milestone.due_date).toLocaleDateString('en-IN', { dateStyle: 'medium' }) %></span>
                <% } %>
              </div>

              <!-- Action forms -->
              <div class="flex items-center space-x-2">
                <!-- Update status form -->
                <form action="/clients/<%= client.id %>/milestones/<%= milestone.id %>/status" method="POST" class="inline flex items-center">
                  <select name="status" onchange="this.form.submit()" class="bg-slate-950 border border-slate-800 rounded-lg text-slate-350 text-[10px] py-1 px-2 focus:outline-none focus:border-[#C29B5C]">
                    <option value="pending" <%= milestone.status === 'pending' ? 'selected' : '' %>>Pending</option>
                    <option value="in_progress" <%= milestone.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                    <option value="completed" <%= milestone.status === 'completed' ? 'selected' : '' %>>Completed</option>
                  </select>
                </form>

                <!-- Delete Form (Admin/Manager) -->
                <% if (user.role === 'admin' || user.role === 'manager') { %>
                  <form action="/clients/<%= client.id %>/milestones/<%= milestone.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Delete this milestone?')">
                    <button type="submit" class="text-slate-500 hover:text-red-400 p-1.5 transition-colors">
                      <i class="fa-solid fa-trash-can text-xs"></i>
                    </button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Add Milestone Form (Admin/Manager) -->
    <% if (user.role === 'admin' || user.role === 'manager') { %>
      <div class="border-t border-slate-800/80 pt-5">
        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-450 mb-4">Add Project Milestone</h4>
        <form action="/clients/<%= client.id %>/milestones" method="POST" class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="sm:col-span-1">
            <input type="text" name="title" required placeholder="Milestone Title *" class="w-full bg-slate-950 border border-slate-800 rounded-xl py-2 px-3 text-slate-300 text-xs focus:outline-none focus:border-[#C29B5C]">
          </div>
          <div class="sm:col-span-1">
            <input type="text" name="description" placeholder="Short description..." class="w-full bg-slate-950 border border-slate-800 rounded-xl py-2 px-3 text-slate-300 text-xs focus:outline-none focus:border-[#C29B5C]">
          </div>
          <div class="sm:col-span-1 flex space-x-2">
            <input type="date" name="due_date" class="w-full bg-slate-950 border border-slate-800 rounded-xl py-2 px-3 text-slate-350 text-xs focus:outline-none focus:border-[#C29B5C]">
            <button type="submit" class="bg-[#C29B5C] hover:bg-yellow-500 text-slate-950 font-bold px-4 rounded-xl text-xs uppercase tracking-wider transition duration-150 flex-shrink-0">
              Add
            </button>
          </div>
        </form>
      </div>
    <% } %>
  </div>

  <!-- Associated Tasks -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl shadow-md overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-800 flex justify-between items-center">
      <div>
        <h3 class="text-lg font-bold text-slate-100 tracking-tight">Assigned Tasks</h3>
        <p class="text-xs text-slate-400 mt-1">Status of tasks linked to this client.</p>
      </div>
      <% if (user.role === 'admin' || user.role === 'manager') { %>
        <a href="/tasks/new?client_id=<%= client.id %>" class="text-xs font-bold text-brand-gold hover:text-slate-200 bg-[#C29B5C]/10 border border-[#C29B5C]/20 hover:bg-[#C29B5C]/20 px-3 py-1.5 rounded-xl transition duration-150 flex items-center space-x-1.5">
          <i class="fa-solid fa-plus"></i>
          <span>Create Task</span>
        </a>
      <% } %>
    </div>

    <% if (tasks.length === 0) { %>
      <div class="p-8 text-center text-slate-500 text-sm">
        No tasks assigned for this client.
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-slate-300">
          <thead class="text-xs uppercase tracking-wider text-slate-500 bg-slate-900 border-b border-slate-800/80">
            <tr>
              <th class="px-6 py-4 font-semibold">Task Title</th>
              <th class="px-6 py-4 font-semibold">Assigned To</th>
              <th class="px-6 py-4 font-semibold">Priority</th>
              <th class="px-6 py-4 font-semibold">Status</th>
              <th class="px-6 py-4 font-semibold">Due Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/60 bg-slate-900/50">
            <% tasks.forEach(task => { %>
              <tr class="hover:bg-slate-800/30 transition-colors duration-150">
                <td class="px-6 py-4 font-semibold text-slate-100">
                  <a href="/tasks/<%= task.id %>" class="hover:text-[#C29B5C] transition-colors"><%= task.title %></a>
                </td>
                <td class="px-6 py-4 text-xs font-medium text-slate-400"><%= task.assignee_name %></td>
                <td class="px-6 py-4 text-xs font-medium">
                  <% if (task.priority === 'high') { %>
                    <span class="text-red-400"><i class="fa-solid fa-triangle-exclamation mr-1"></i>High</span>
                  <% } else if (task.priority === 'medium') { %>
                    <span class="text-amber-400"><i class="fa-solid fa-circle-exclamation mr-1"></i>Medium</span>
                  <% } else { %>
                    <span class="text-slate-400"><i class="fa-solid fa-circle-info mr-1"></i>Low</span>
                  <% } %>
                </td>
                <td class="px-6 py-4">
                  <% if (task.status === 'not_started') { %>
                    <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-slate-500/20 text-slate-400 border border-slate-500/20 uppercase tracking-wide">Not Started</span>
                  <% } else if (task.status === 'in_progress') { %>
                    <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-amber-500/10 text-amber-400 border border-amber-500/20 uppercase tracking-wide">In Progress</span>
                  <% } else if (task.status === 'under_review') { %>
                    <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-purple-500/10 text-purple-400 border border-purple-500/20 uppercase tracking-wide">Under Review</span>
                  <% } else if (task.status === 'completed') { %>
                    <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 uppercase tracking-wide">Completed</span>
                  <% } %>
                </td>
                <td class="px-6 py-4 text-xs text-slate-400 select-all">
                  <%= task.due_date ? new Date(task.due_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : 'No Deadline' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Client Invoices Section -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl shadow-md overflow-hidden animate-fade-in">
    <div class="px-6 py-5 border-b border-slate-800 flex justify-between items-center">
      <div>
        <h3 class="text-lg font-bold text-slate-100 tracking-tight">Project Invoices</h3>
        <p class="text-xs text-slate-400 mt-1">Track billed amounts, status, and reminders.</p>
      </div>
    </div>

    <!-- Invoices List -->
    <% if (invoices.length === 0) { %>
      <div class="p-8 text-center text-slate-500 text-sm">
        No invoices generated for this client.
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-slate-350">
          <thead class="text-xs uppercase tracking-wider text-slate-500 bg-slate-900 border-b border-slate-800/80">
            <tr>
              <th class="px-6 py-4 font-semibold">Invoice #</th>
              <th class="px-6 py-4 font-semibold text-right">Amount</th>
              <th class="px-6 py-4 font-semibold">Due Date</th>
              <th class="px-6 py-4 font-semibold">Status</th>
              <th class="px-6 py-4 font-semibold">Reminder Status</th>
              <th class="px-6 py-4 font-semibold text-center">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/60 bg-slate-900/50">
            <% invoices.forEach(invoice => { %>
              <tr class="hover:bg-slate-800/30 transition-colors duration-150 text-xs">
                <!-- Number -->
                <td class="px-6 py-4 font-bold text-slate-200 select-all"><%= invoice.invoice_number %></td>
                
                <!-- Amount -->
                <td class="px-6 py-4 text-right text-slate-200 font-semibold select-all">₹<%= parseFloat(invoice.amount).toLocaleString('en-IN') %></td>
                
                <!-- Due Date -->
                <td class="px-6 py-4 text-slate-400"><%= new Date(invoice.due_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                
                <!-- Status -->
                <td class="px-6 py-4">
                  <% if (invoice.status === 'paid') { %>
                    <span class="px-2.5 py-0.5 rounded text-[9px] font-bold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 uppercase tracking-wide">Paid</span>
                  <% } else { %>
                    <span class="px-2.5 py-0.5 rounded text-[9px] font-bold bg-rose-500/10 text-rose-400 border border-rose-500/20 uppercase tracking-wide">Unpaid</span>
                  <% } %>
                </td>

                <!-- Reminder Status -->
                <td class="px-6 py-4 text-slate-400">
                  <% if (invoice.reminder_sent_at) { %>
                    <span class="text-slate-400"><i class="fa-solid fa-bell-check text-emerald-500 mr-1"></i>Sent: <%= new Date(invoice.reminder_sent_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></span>
                  <% } else { %>
                    <span class="text-slate-500">Not Sent</span>
                  <% } %>
                </td>

                <!-- Actions -->
                <td class="px-6 py-4">
                  <div class="flex items-center justify-center space-x-2">
                    <a href="/clients/<%= client.id %>/invoices/<%= invoice.id %>/print" target="_blank" class="text-[#C29B5C] hover:underline bg-slate-950 px-2.5 py-1.5 rounded-lg border border-slate-800" title="View/Print Invoice">
                      <i class="fa-solid fa-print mr-1"></i>Print
                    </a>

                    <% if ((user.role === 'admin' || user.role === 'manager') && invoice.status === 'unpaid') { %>
                      <!-- Send Reminder Form -->
                      <form action="/clients/<%= client.id %>/invoices/<%= invoice.id %>/reminder" method="POST" class="inline">
                        <button type="submit" class="text-slate-350 hover:text-slate-100 bg-slate-950 hover:bg-slate-800 px-2 py-1.5 rounded-lg border border-slate-800" title="Send Payment Reminder">
                          <i class="fa-solid fa-bell mr-1"></i>Remind
                        </button>
                      </form>

                      <!-- Mark Paid Form -->
                      <form action="/clients/<%= client.id %>/invoices/<%= invoice.id %>/status" method="POST" class="inline">
                        <input type="hidden" name="status" value="paid">
                        <button type="submit" class="text-emerald-400 hover:text-emerald-350 bg-slate-950 hover:bg-slate-800 px-2 py-1.5 rounded-lg border border-slate-800" title="Mark Paid">
                          <i class="fa-solid fa-check mr-1"></i>Paid
                        </button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <!-- Generate Invoice Form (Admin/Manager) -->
    <% if (user.role === 'admin' || user.role === 'manager') { %>
      <div class="p-6 border-t border-slate-800 bg-slate-950/20">
        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-450 mb-4">Generate New Project Invoice</h4>
        <form action="/clients/<%= client.id %>/invoices" method="POST" class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <input type="text" name="invoice_number" required placeholder="Invoice Number (e.g. INV-001) *" class="w-full bg-slate-950 border border-slate-800 rounded-xl py-2 px-3 text-slate-300 text-xs focus:outline-none focus:border-[#C29B5C]">
          </div>
          <div>
            <input type="number" step="0.01" name="amount" required placeholder="Invoice Amount (INR) *" class="w-full bg-slate-950 border border-slate-800 rounded-xl py-2 px-3 text-slate-300 text-xs focus:outline-none focus:border-[#C29B5C]">
          </div>
          <div class="flex space-x-2">
            <input type="date" name="due_date" required class="w-full bg-slate-950 border border-slate-800 rounded-xl py-2 px-3 text-slate-350 text-xs focus:outline-none focus:border-[#C29B5C]">
            <button type="submit" class="bg-[#C29B5C] hover:bg-yellow-500 text-slate-950 font-bold px-4 rounded-xl text-xs uppercase tracking-wider transition duration-150 flex-shrink-0">
              Generate
            </button>
          </div>
        </form>
      </div>
    <% } %>
  </div>

  <!-- Billing / Payments History -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl shadow-md overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-800 flex justify-between items-center">
      <div>
        <h3 class="text-lg font-bold text-slate-100 tracking-tight">Payment Ledger</h3>
        <p class="text-xs text-slate-400 mt-1">Historical ledger of transaction credits.</p>
      </div>
      <% if (user.role === 'admin' || user.role === 'manager') { %>
        <a href="/payments/new?client_id=<%= client.id %>" class="text-xs font-bold text-brand-gold hover:text-slate-200 bg-[#C29B5C]/10 border border-[#C29B5C]/20 hover:bg-[#C29B5C]/20 px-3 py-1.5 rounded-xl transition duration-150 flex items-center space-x-1.5">
          <i class="fa-solid fa-plus"></i>
          <span>Record Payment</span>
        </a>
      <% } %>
    </div>

    <% if (payments.length === 0) { %>
      <div class="p-8 text-center text-slate-500 text-sm">
        No payment records found for this client.
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-slate-300">
          <thead class="text-xs uppercase tracking-wider text-slate-500 bg-slate-900 border-b border-slate-800/80">
            <tr>
              <th class="px-6 py-4 font-semibold">Payment Date</th>
              <th class="px-6 py-4 font-semibold text-right">Amount</th>
              <th class="px-6 py-4 font-semibold">Type</th>
              <th class="px-6 py-4 font-semibold">Mode</th>
              <th class="px-6 py-4 font-semibold">Recorded By</th>
              <th class="px-6 py-4 font-semibold">Notes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/60 bg-slate-900/50">
            <% payments.forEach(payment => { %>
              <tr class="hover:bg-slate-800/30 transition-colors duration-150">
                <td class="px-6 py-4 text-xs font-medium select-all">
                  <%= new Date(payment.payment_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </td>
                <td class="px-6 py-4 text-right text-emerald-400 font-bold select-all">₹<%= parseFloat(payment.amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                <td class="px-6 py-4 text-xs capitalize"><span class="px-2 py-0.5 rounded bg-slate-800 text-slate-300"><%= payment.payment_type %></span></td>
                <td class="px-6 py-4 text-xs uppercase font-semibold text-slate-400"><%= payment.payment_mode.replace('_', ' ') %></td>
                <td class="px-6 py-4 text-xs text-slate-400"><%= payment.recorder_name %></td>
                <td class="px-6 py-4 text-xs text-slate-400 max-w-xs truncate" title="<%= payment.notes %>"><%= payment.notes || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Client Progress Reports -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl shadow-md overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-800">
      <h3 class="text-lg font-bold text-slate-100 tracking-tight">Client Progress Reports</h3>
      <p class="text-xs text-slate-400 mt-1">Submitted task progression updates and comments from the client portal.</p>
    </div>

    <% if (progressUpdates.length === 0) { %>
      <div class="p-8 text-center text-slate-500 text-sm">
        No progress reports submitted by this client yet.
      </div>
    <% } else { %>
      <div class="divide-y divide-slate-800/80 max-h-96 overflow-y-auto">
        <% progressUpdates.forEach(update => { %>
          <div class="p-6 bg-slate-900/50 hover:bg-slate-850/20 transition-all duration-150 space-y-2">
            <div class="flex justify-between items-center text-xs text-slate-500">
              <span class="font-bold text-[#C29B5C] uppercase tracking-wider text-[9px]">Client Status Update</span>
              <span><%= new Date(update.created_at).toLocaleString('en-IN') %></span>
            </div>
            <p class="text-slate-300 text-xs leading-relaxed whitespace-pre-wrap"><%= update.message %></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
