<%- include('../partials/header') %>

<div class="space-y-8 animate-fade-in">
  <!-- Dashboard Title & Month Selector -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between space-y-4 md:space-y-0">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-100">Performance Dashboard</h1>
      <p class="text-sm text-slate-400 mt-1">Real-time revenue, client stages, and team operations.</p>
    </div>
    
    <!-- Month Filter Form -->
    <form action="/dashboard" method="GET" class="flex items-center space-x-3 bg-slate-900 border border-slate-800 p-2 rounded-xl shadow-sm">
      <label for="month-select" class="text-xs font-semibold uppercase tracking-wider text-slate-400 px-2">Select Month</label>
      <input type="month" id="month-select" name="month" value="<%= selectedMonth %>" 
             onchange="this.form.submit()" 
             class="bg-slate-950 border border-slate-800 rounded-lg text-slate-200 text-xs py-1.5 px-3 focus:outline-none focus:border-[#C29B5C]">
    </form>
  </div>

  <!-- Main Metric Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Monthly Revenue Card -->
    <div class="bg-slate-900 border border-slate-800/80 rounded-2xl p-6 relative overflow-hidden group shadow-md transition-all duration-200 hover:border-slate-700/80">
      <div class="absolute top-0 right-0 p-4 opacity-10 text-brand-gold text-5xl">
        <i class="fa-solid fa-indian-rupee-sign"></i>
      </div>
      <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Revenue (Selected Month)</p>
      <h3 class="text-3xl font-black text-slate-100 mt-3 select-all">₹<%= parseFloat(monthlyRevenue).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></h3>
      <div class="flex items-center space-x-2 mt-4 text-xs text-slate-400">
        <span class="text-brand-gold bg-[#C29B5C]/10 px-2 py-0.5 rounded font-semibold"><%= new Date(selectedMonth + '-02').toLocaleString('default', { month: 'long', year: 'numeric' }) %></span>
      </div>
    </div>

    <!-- Pending Payments Card -->
    <div class="bg-slate-900 border border-slate-800/80 rounded-2xl p-6 relative overflow-hidden group shadow-md transition-all duration-200 hover:border-slate-700/80">
      <div class="absolute top-0 right-0 p-4 opacity-10 text-red-500 text-5xl">
        <i class="fa-solid fa-clock-rotate-left"></i>
      </div>
      <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Total Pending Dues</p>
      <h3 class="text-3xl font-black text-red-400 mt-3 select-all">₹<%= parseFloat(pendingSummary.amount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></h3>
      <p class="text-xs text-slate-400 mt-4">
        Spread across <span class="text-red-400 font-bold"><%= pendingSummary.count %></span> clients
      </p>
    </div>

    <!-- Total Clients Card -->
    <div class="bg-slate-900 border border-slate-800/80 rounded-2xl p-6 relative overflow-hidden group shadow-md transition-all duration-200 hover:border-slate-700/80">
      <div class="absolute top-0 right-0 p-4 opacity-10 text-sky-500 text-5xl">
        <i class="fa-solid fa-user-group"></i>
      </div>
      <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Active Clients</p>
      <h3 class="text-3xl font-black text-slate-100 mt-3"><%= clientStats.total_clients %></h3>
      <div class="flex flex-wrap gap-1.5 mt-3.5">
        <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-sky-500/10 text-sky-400 uppercase">Lead: <%= clientStats.lead_count %></span>
        <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-amber-500/10 text-amber-400 uppercase">Ongoing: <%= clientStats.ongoing_count %></span>
        <span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-emerald-500/10 text-emerald-400 uppercase">Done: <%= clientStats.completed_count %></span>
      </div>
    </div>

    <!-- Active Team Members Card -->
    <div class="bg-slate-900 border border-slate-800/80 rounded-2xl p-6 relative overflow-hidden group shadow-md transition-all duration-200 hover:border-slate-700/80">
      <div class="absolute top-0 right-0 p-4 opacity-10 text-emerald-500 text-5xl">
        <i class="fa-solid fa-users"></i>
      </div>
      <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Team Force</p>
      <h3 class="text-3xl font-black text-slate-100 mt-3"><%= totalTeamMembers %></h3>
      <p class="text-xs text-slate-400 mt-4">
        Managing <span class="text-brand-gold font-bold"><%= taskStats.total - taskStats.completed %></span> active tasks
      </p>
    </div>
  </div>

  <!-- Charts & Tasks Sections -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Revenue Chart (2/3 width on large screens) -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 lg:col-span-2 shadow-md">
      <h3 class="text-lg font-bold text-slate-100 tracking-tight mb-4">Revenue Trend (Last 6 Months)</h3>
      <div class="h-80 w-full">
        <canvas id="revenueChart"></canvas>
      </div>
    </div>

    <!-- Task Breakdown (1/3 width) -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-md flex flex-col justify-between">
      <div>
        <h3 class="text-lg font-bold text-slate-100 tracking-tight mb-4">Tasks Operations</h3>
        <p class="text-xs text-slate-400 mb-6">Current breakdown of task progression statuses.</p>
        
        <div class="space-y-4">
          <!-- Not Started -->
          <div>
            <div class="flex justify-between text-xs font-semibold mb-1">
              <span class="text-slate-400">Not Started</span>
              <span class="text-slate-200"><%= taskStats.not_started %> / <%= taskStats.total %></span>
            </div>
            <div class="w-full h-2 bg-slate-950 rounded-full overflow-hidden">
              <div class="h-full bg-slate-500" style="width: <%= taskStats.total > 0 ? (taskStats.not_started / taskStats.total) * 100 : 0 %>%"></div>
            </div>
          </div>
          
          <!-- In Progress -->
          <div>
            <div class="flex justify-between text-xs font-semibold mb-1">
              <span class="text-amber-400">In Progress</span>
              <span class="text-slate-200"><%= taskStats.in_progress %> / <%= taskStats.total %></span>
            </div>
            <div class="w-full h-2 bg-slate-950 rounded-full overflow-hidden">
              <div class="h-full bg-amber-500" style="width: <%= taskStats.total > 0 ? (taskStats.in_progress / taskStats.total) * 100 : 0 %>%"></div>
            </div>
          </div>

          <!-- Under Review -->
          <div>
            <div class="flex justify-between text-xs font-semibold mb-1">
              <span class="text-purple-400">Under Review</span>
              <span class="text-slate-200"><%= taskStats.under_review %> / <%= taskStats.total %></span>
            </div>
            <div class="w-full h-2 bg-slate-950 rounded-full overflow-hidden">
              <div class="h-full bg-purple-500" style="width: <%= taskStats.total > 0 ? (taskStats.under_review / taskStats.total) * 100 : 0 %>%"></div>
            </div>
          </div>

          <!-- Completed -->
          <div>
            <div class="flex justify-between text-xs font-semibold mb-1">
              <span class="text-emerald-400">Completed</span>
              <span class="text-slate-200"><%= taskStats.completed %> / <%= taskStats.total %></span>
            </div>
            <div class="w-full h-2 bg-slate-950 rounded-full overflow-hidden">
              <div class="h-full bg-emerald-500" style="width: <%= taskStats.total > 0 ? (taskStats.completed / taskStats.total) * 100 : 0 %>%"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 pt-4 border-t border-slate-800 flex justify-between items-center text-xs">
        <span class="text-slate-500">Completed Tasks Ratio:</span>
        <span class="font-bold text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded">
          <%= taskStats.total > 0 ? Math.round((taskStats.completed / taskStats.total) * 100) : 0 %>%
        </span>
      </div>
    </div>
  </div>

  <!-- Upcoming Payments List Table -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl shadow-md overflow-hidden">
    <div class="px-6 py-5 border-b border-slate-800 flex justify-between items-center">
      <div>
        <h3 class="text-lg font-bold text-slate-100 tracking-tight">Upcoming Payments & Dues</h3>
        <p class="text-xs text-slate-400 mt-1">Ongoing or On Hold client accounts with outstanding project balances.</p>
      </div>
      <a href="/payments/new" class="text-xs font-bold text-brand-gold hover:text-slate-200 bg-[#C29B5C]/10 border border-[#C29B5C]/20 hover:bg-[#C29B5C]/20 px-3 py-1.5 rounded-xl transition duration-150 flex items-center space-x-1.5">
        <i class="fa-solid fa-plus"></i>
        <span>Record Payment</span>
      </a>
    </div>

    <% if (upcomingPayments.length === 0) { %>
      <div class="p-8 text-center text-slate-500 text-sm">
        <i class="fa-solid fa-check-circle text-emerald-500 text-xl mb-2 block"></i>
        All ongoing clients have fully paid their project values! No upcoming payments pending.
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-slate-300">
          <thead class="text-xs uppercase tracking-wider text-slate-500 bg-slate-900 border-b border-slate-800/80">
            <tr>
              <th class="px-6 py-4 font-semibold">Client Name</th>
              <th class="px-6 py-4 font-semibold">Service Type</th>
              <th class="px-6 py-4 font-semibold">Project Status</th>
              <th class="px-6 py-4 font-semibold text-right">Project Value</th>
              <th class="px-6 py-4 font-semibold text-right">Amount Paid</th>
              <th class="px-6 py-4 font-semibold text-right text-brand-gold">Outstanding Balance</th>
              <th class="px-6 py-4 font-semibold text-center">Last Payment Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/60 bg-slate-900/50">
            <% upcomingPayments.forEach(client => { %>
              <tr class="hover:bg-slate-800/30 transition-colors duration-150">
                <td class="px-6 py-4 font-semibold text-slate-100">
                  <a href="/clients/<%= client.id %>" class="hover:text-[#C29B5C] transition-colors"><%= client.name %></a>
                </td>
                <td class="px-6 py-4 text-xs font-medium text-slate-400 capitalize"><%= client.service_type.replace('_', ' ') %></td>
                <td class="px-6 py-4">
                  <% if (client.status === 'ongoing') { %>
                    <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-amber-500/10 text-amber-400 border border-amber-500/20 uppercase tracking-wide">Ongoing</span>
                  <% } else if (client.status === 'on_hold') { %>
                    <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-slate-500/25 text-slate-400 border border-slate-500/20 uppercase tracking-wide">On Hold</span>
                  <% } %>
                </td>
                <td class="px-6 py-4 text-right select-all">₹<%= parseFloat(client.total_value).toLocaleString('en-IN') %></td>
                <td class="px-6 py-4 text-right text-emerald-400 select-all">₹<%= parseFloat(client.paid_amount).toLocaleString('en-IN') %></td>
                <td class="px-6 py-4 text-right text-[#C29B5C] font-semibold select-all">₹<%= parseFloat(client.pending_amount).toLocaleString('en-IN') %></td>
                <td class="px-6 py-4 text-center text-xs text-slate-500 select-all">
                  <%= client.last_payment_date ? new Date(client.last_payment_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : 'No Payments Yet' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<!-- Chart.js and Dashboard Init Scripts -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('revenueChart').getContext('2d');
    
    // Parse labels and values from EJS variables safely
    const labels = <%- JSON.stringify(chartLabels) %>;
    const dataValues = <%- JSON.stringify(chartValues) %>;
    
    const revenueChart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{
          label: 'Revenue (₹)',
          data: dataValues,
          backgroundColor: 'rgba(194, 155, 92, 0.2)', // brand-gold with opacity
          borderColor: '#C29B5C',
          borderWidth: 2,
          borderRadius: 8,
          hoverBackgroundColor: 'rgba(194, 155, 92, 0.45)',
          hoverBorderColor: '#D5B98A',
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: false
          },
          tooltip: {
            backgroundColor: '#0f172a',
            titleFont: { family: 'Outfit', size: 13 },
            bodyFont: { family: 'Inter', size: 12 },
            borderColor: '#334155',
            borderWidth: 1,
            padding: 12,
            callbacks: {
              label: function(context) {
                return ' Revenue: ₹' + context.raw.toLocaleString('en-IN');
              }
            }
          }
        },
        scales: {
          x: {
            grid: {
              display: false
            },
            ticks: {
              color: '#94a3b8',
              font: {
                family: 'Inter',
                size: 11
              }
            }
          },
          y: {
            grid: {
              color: '#334155',
              drawBorder: false
            },
            ticks: {
              color: '#94a3b8',
              font: {
                family: 'Inter',
                size: 11
              },
              callback: function(value) {
                if (value >= 1000) {
                  return '₹' + (value / 1000) + 'k';
                }
                return '₹' + value;
              }
            }
          }
        }
      }
    });
  });
</script>

<%- include('../partials/footer') %>
