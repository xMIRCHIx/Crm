<!-- Client Portal Sidebar -->
<aside class="w-64 bg-slate-900 border-r border-slate-800 flex flex-col h-full flex-shrink-0">
  <!-- Brand Logo Section -->
  <div class="px-6 py-6 border-b border-slate-800 flex items-center justify-between">
    <div class="flex items-center space-x-3">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-yellow-600 to-[#C29B5C] flex items-center justify-center shadow-md">
        <i class="fa-solid fa-crown text-slate-950 font-bold"></i>
      </div>
      <div>
        <h1 class="text-lg font-bold text-slate-100 tracking-tight leading-none">Growlix</h1>
        <span class="text-[10px] uppercase font-bold tracking-widest text-[#C29B5C]">Client Portal</span>
      </div>
    </div>
  </div>

  <!-- Navigation Links -->
  <nav class="flex-1 px-4 py-6 space-y-1.5 overflow-y-auto">
    <!-- Portal Home / Dashboard -->
    <a href="/portal" class="flex items-center space-x-3 px-4 py-3 rounded-xl transition-all duration-200 <%= path === '/portal' ? 'bg-[#C29B5C]/10 text-[#C29B5C] font-semibold border-l-4 border-[#C29B5C]' : 'text-slate-400 hover:bg-slate-800/50 hover:text-slate-200' %>">
      <i class="fa-solid fa-chart-line w-5"></i>
      <span class="text-sm">My Dashboard</span>
    </a>

    <!-- Invoices -->
    <a href="/portal/invoices" class="flex items-center space-x-3 px-4 py-3 rounded-xl transition-all duration-200 <%= path.startsWith('/portal/invoices') ? 'bg-[#C29B5C]/10 text-[#C29B5C] font-semibold border-l-4 border-[#C29B5C]' : 'text-slate-400 hover:bg-slate-800/50 hover:text-slate-200' %>">
      <i class="fa-solid fa-file-invoice-dollar w-5"></i>
      <span class="text-sm">Invoices</span>
    </a>

    <!-- Support Tickets -->
    <a href="/portal/tickets" class="flex items-center space-x-3 px-4 py-3 rounded-xl transition-all duration-200 <%= path.startsWith('/portal/tickets') ? 'bg-[#C29B5C]/10 text-[#C29B5C] font-semibold border-l-4 border-[#C29B5C]' : 'text-slate-400 hover:bg-slate-800/50 hover:text-slate-200' %>">
      <i class="fa-solid fa-headset w-5"></i>
      <span class="text-sm">Support Tickets</span>
    </a>
  </nav>

  <!-- Bottom Profile Summary -->
  <div class="p-4 border-t border-slate-800 bg-slate-900/50">
    <div class="flex items-center space-x-3">
      <div class="w-9 h-9 rounded-full bg-[#C29B5C]/10 border border-[#C29B5C]/20 flex items-center justify-center text-[#C29B5C] font-bold uppercase text-sm">
        <%= user.name.charAt(0) %>
      </div>
      <div class="flex-1 min-w-0">
        <h4 class="text-xs font-semibold text-slate-200 truncate"><%= user.name %></h4>
        <span class="text-[10px] font-medium text-slate-500 truncate block"><%= user.email %></span>
      </div>
    </div>
  </div>
</aside>
