<%- include('../partials/header') %>

<div class="space-y-8 animate-fade-in">
  <!-- Page Header -->
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-100">Billed Invoices</h1>
      <p class="text-sm text-slate-400 mt-1">Review billing statement records, payment statuses, and invoice documents.</p>
    </div>
  </div>

  <!-- Invoices Table Section -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-sm">
    <div class="p-6 border-b border-slate-800 flex justify-between items-center">
      <h3 class="text-xs font-bold uppercase tracking-wider text-slate-500">Billing History Ledger</h3>
    </div>

    <% if (invoices.length === 0) { %>
      <div class="text-center py-16 text-slate-500 space-y-3">
        <i class="fa-solid fa-file-invoice text-4xl opacity-30"></i>
        <p class="text-sm">No invoice statements have been billed to your account yet.</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-slate-800 text-[10px] font-bold uppercase tracking-wider text-slate-500 bg-slate-950/40">
              <th class="px-6 py-4">Invoice #</th>
              <th class="px-6 py-4">Billing Date</th>
              <th class="px-6 py-4">Due Date</th>
              <th class="px-6 py-4">Status</th>
              <th class="px-6 py-4 text-right">Amount Due</th>
              <th class="px-6 py-4 text-center">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/60 text-slate-300 text-xs">
            <% invoices.forEach(invoice => { %>
              <tr class="hover:bg-slate-950/20 transition-colors">
                <!-- Invoice Number -->
                <td class="px-6 py-4 font-bold text-slate-200 select-all"><%= invoice.invoice_number %></td>
                
                <!-- Billing Date -->
                <td class="px-6 py-4"><%= new Date(invoice.created_at).toLocaleDateString('en-IN', { dateStyle: 'medium' }) %></td>
                
                <!-- Due Date -->
                <td class="px-6 py-4"><%= new Date(invoice.due_date).toLocaleDateString('en-IN', { dateStyle: 'medium' }) %></td>
                
                <!-- Status -->
                <td class="px-6 py-4">
                  <% if (invoice.status === 'paid') { %>
                    <span class="px-2.5 py-0.5 rounded-full text-[9px] font-bold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 uppercase tracking-wide">Paid</span>
                  <% } else { %>
                    <span class="px-2.5 py-0.5 rounded-full text-[9px] font-bold bg-rose-500/10 text-rose-400 border border-rose-500/20 uppercase tracking-wide">Unpaid</span>
                  <% } %>
                </td>

                <!-- Amount -->
                <td class="px-6 py-4 text-right font-semibold select-all text-slate-200">₹<%= parseFloat(invoice.amount).toLocaleString('en-IN') %></td>

                <!-- Actions -->
                <td class="px-6 py-4 text-center">
                  <div class="flex items-center justify-center space-x-2.5">
                    <a href="/clients/<%= client.id %>/invoices/<%= invoice.id %>/print" target="_blank" class="text-slate-400 hover:text-[#C29B5C] transition-colors flex items-center space-x-1.5 bg-slate-950 px-2.5 py-1.5 rounded-lg border border-slate-800" title="Print/View Statement">
                      <i class="fa-solid fa-print text-[10px]"></i>
                      <span>View Statement</span>
                    </a>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
