<%- include('../partials/header') %>

<div class="max-w-3xl mx-auto space-y-6 animate-fade-in">
  <!-- Page Header / Back Button -->
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-3">
      <a href="/portal/tickets" class="text-slate-400 hover:text-slate-200 bg-slate-900 border border-slate-800 p-2.5 rounded-xl transition duration-150 shadow-sm" title="Back to Tickets">
        <i class="fa-solid fa-arrow-left"></i>
      </a>
      <div>
        <h1 class="text-xl font-extrabold tracking-tight text-slate-100"><%= ticket.title %></h1>
        <div class="flex items-center space-x-2 mt-1 text-[10px] text-slate-500 font-medium uppercase tracking-wider">
          <span>#<%= ticket.id %></span>
          <span>&bull;</span>
          <span>Opened on: <%= new Date(ticket.created_at).toLocaleDateString('en-IN', { dateStyle: 'medium' }) %></span>
        </div>
      </div>
    </div>
    
    <!-- Status Badge -->
    <span class="px-3 py-1 rounded-full text-xs font-bold border uppercase tracking-wider
      <%= ticket.status === 'open' ? 'bg-sky-500/10 text-sky-400 border-sky-500/20' : 
          ticket.status === 'in_progress' ? 'bg-amber-500/10 text-amber-400 border-amber-500/20' : 
          'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' %>">
      <%= ticket.status.replace('_', ' ') %>
    </span>
  </div>

  <!-- Ticket Conversation Thread -->
  <div class="space-y-4">
    
    <!-- 1. Original Client Ticket Post -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-sm space-y-4">
      <div class="flex items-center justify-between border-b border-slate-800/80 pb-3">
        <div class="flex items-center space-x-2.5">
          <div class="w-8 h-8 rounded-full bg-[#C29B5C]/15 border border-[#C29B5C]/20 flex items-center justify-center text-[#C29B5C] font-bold text-xs uppercase">
            YOU
          </div>
          <div>
            <h4 class="text-xs font-bold text-slate-200">Your Description</h4>
            <span class="text-[9px] text-slate-500 font-medium block">Original Request Category: <%= ticket.category.replace('_', ' ') %> &bull; <%= ticket.priority %> Priority</span>
          </div>
        </div>
      </div>
      <p class="text-slate-350 text-xs leading-relaxed whitespace-pre-wrap"><%= ticket.description %></p>
    </div>

    <!-- 2. Replies List -->
    <% if (replies.length > 0) { %>
      <div class="space-y-4">
        <% replies.forEach(reply => { %>
          <% const isAdminParty = reply.user_role === 'admin' || reply.user_role === 'team_member'; %>
          
          <div class="border rounded-2xl p-6 shadow-sm space-y-3 
            <%= isAdminParty ? 'bg-[#C29B5C]/5 border-[#C29B5C]/15 ml-6' : 'bg-slate-900 border-slate-800' %>">
            
            <div class="flex items-center justify-between border-b border-slate-800/80 pb-2.5">
              <div class="flex items-center space-x-2.5">
                <div class="w-7 h-7 rounded-full flex items-center justify-center font-bold text-xs uppercase
                  <%= isAdminParty ? 'bg-[#C29B5C] text-slate-950' : 'bg-slate-800 text-slate-400 border border-slate-700' %>">
                  <%= reply.user_name.charAt(0) %>
                </div>
                <div>
                  <h4 class="text-xs font-bold <%= isAdminParty ? 'text-[#C29B5C]' : 'text-slate-200' %>">
                    <%= reply.user_name %>
                    <% if (isAdminParty) { %>
                      <span class="ml-1 px-1.5 py-0.5 rounded text-[8px] bg-[#C29B5C]/20 text-[#C29B5C] uppercase tracking-wide">Support Team</span>
                    <% } %>
                  </h4>
                  <span class="text-[9px] text-slate-500 font-medium block"><%= new Date(reply.created_at).toLocaleString('en-IN') %></span>
                </div>
              </div>
            </div>
            
            <p class="text-slate-300 text-xs leading-relaxed whitespace-pre-wrap"><%= reply.message %></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- 3. Post Reply Card -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-sm">
    <form action="/portal/tickets/<%= ticket.id %>/reply" method="POST" class="space-y-4">
      <div>
        <label for="message" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Write Reply</label>
        <textarea name="message" id="message" rows="4" required
                  placeholder="Type your reply here..."
                  class="w-full bg-slate-950 border border-slate-800 rounded-xl py-3 px-4 text-slate-200 text-xs placeholder-slate-650 focus:outline-none focus:border-[#C29B5C]"></textarea>
      </div>

      <div class="flex justify-between items-center">
        <p class="text-[10px] text-slate-500">
          <% if (ticket.status === 'resolved') { %>
            <i class="fa-solid fa-circle-info text-amber-500 mr-1"></i>Posting a reply will automatically re-open this ticket.
          <% } %>
        </p>
        <button type="submit" class="bg-gradient-to-r from-yellow-600 to-[#C29B5C] hover:from-amber-600 hover:to-yellow-500 text-slate-950 font-bold py-2.5 px-6 rounded-xl transition duration-150 text-xs uppercase tracking-wider shadow-lg flex items-center space-x-1.5">
          <i class="fa-solid fa-reply"></i>
          <span>Send Reply</span>
        </button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
