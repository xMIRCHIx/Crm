<%- include('../partials/header') %>

<div class="max-w-xl mx-auto space-y-8 animate-fade-in">
  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 shadow-2xl relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-1 bg-[#C29B5C]"></div>

    <!-- Icon & Heading -->
    <div class="text-center mb-6">
      <div class="w-14 h-14 bg-emerald-500/10 rounded-full flex items-center justify-center text-emerald-400 text-3xl mx-auto mb-4">
        <i class="fa-solid fa-circle-check"></i>
      </div>
      <h1 class="text-2xl font-extrabold text-slate-100">Team Account Generated</h1>
      <p class="text-slate-400 text-xs mt-1">Copy the credentials below. The temporary password is shown only once.</p>
    </div>

    <!-- Credentials Card -->
    <div class="bg-slate-950/80 border border-slate-800/80 rounded-xl p-5 space-y-4">
      <!-- Name -->
      <div class="flex justify-between items-center text-sm">
        <span class="text-slate-500">Name:</span>
        <span class="font-semibold text-slate-200"><%= name %></span>
      </div>
      
      <!-- Email -->
      <div class="flex justify-between items-center text-sm border-t border-slate-900 pt-3">
        <span class="text-slate-500">Login Email:</span>
        <span class="font-semibold text-slate-200 select-all"><%= email %></span>
      </div>

      <!-- Password -->
      <div class="flex justify-between items-center text-sm border-t border-slate-900 pt-3">
        <span class="text-slate-500">Temporary Password:</span>
        <div class="flex items-center space-x-2">
          <code id="temp-password" class="font-mono bg-slate-900 px-2 py-1 rounded text-[#C29B5C] font-semibold text-sm select-all"><%= tempPassword %></code>
          <button onclick="copyPassword()" class="text-slate-400 hover:text-slate-200 transition-colors p-1" title="Copy to clipboard">
            <i id="copy-icon" class="fa-regular fa-copy"></i>
          </button>
        </div>
      </div>
    </div>

    <!-- Alert Warning -->
    <div class="mt-6 bg-amber-500/10 border border-amber-500/25 text-amber-400 p-4 rounded-xl flex items-start space-x-3 text-xs">
      <i class="fa-solid fa-triangle-exclamation text-base mt-0.5 flex-shrink-0"></i>
      <p class="font-medium leading-relaxed">
        <strong>Important:</strong> Copy the temporary password above and share it securely with <%= name %>. They will use it to log in and can change it later. You will not be able to retrieve this password after leaving this page.
      </p>
    </div>

    <!-- Action Back button -->
    <div class="mt-8 pt-6 border-t border-slate-800 flex justify-end">
      <a href="/team" class="bg-[#C29B5C] hover:bg-amber-600 text-slate-950 font-bold py-2.5 px-6 rounded-xl text-xs transition duration-150 uppercase tracking-wider shadow">
        Go to Team Directory
      </a>
    </div>
  </div>
</div>

<script>
  function copyPassword() {
    const passwordText = document.getElementById('temp-password').innerText;
    navigator.clipboard.writeText(passwordText).then(() => {
      const icon = document.getElementById('copy-icon');
      icon.className = "fa-solid fa-check text-emerald-400";
      setTimeout(() => {
        icon.className = "fa-regular fa-copy";
      }, 2000);
    }).catch(err => {
      alert('Could not copy text: ' + err);
    });
  }
</script>

<%- include('../partials/footer') %>
